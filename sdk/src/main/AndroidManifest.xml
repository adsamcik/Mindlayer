<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!--
        v0.10 consent architecture: the BIND_ML_SERVICE signature|knownSigner
        permission was removed from the Mindlayer service, so the SDK no
        longer declares a <uses-permission> for it. Any app may bind; access
        to AIDL methods is gated by per-app user consent (the consent-Intent
        flow), not an OS-level signature permission. See
        docs/CONSENT_ARCHITECTURE.md and SDK_INTEGRATION.md.
    -->

    <!--
        F-024: SDK manifest hint — keep the encrypted history DB and SDK key
        prefs out of host-app backups. The host app's manifest wins for
        `android:allowBackup` / `android:dataExtractionRules` (the manifest
        merger applies host-app values). When the host app does NOT provide
        its own dataExtractionRules, ours is used. When the host DOES provide
        rules, the host is expected to merge in `databases/mindlayer_history.db`
        and `mindlayer_sdk_db_*` SharedPreferences exclusions itself; see
        `SDK_INTEGRATION.md`.
    -->
    <application
        android:dataExtractionRules="@xml/sdk_data_extraction_rules"
        tools:targetApi="s" />
</manifest>
