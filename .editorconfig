# EditorConfig — consistent formatting across editors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4

[*.xml]
indent_size = 4

[*.{json,toml,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[gradlew.bat]
end_of_line = crlf

[*.{gradle,gradle.kts}]
indent_size = 4
