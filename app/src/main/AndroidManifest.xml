<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.HIDE_OVERLAY_WINDOWS" />
    <!-- F-029: BiometricPrompt for Approve / Revoke gating in the dashboard
         and the consent screen. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        v0.10 consent architecture (docs/CONSENT_ARCHITECTURE.md):
        Mindlayer no longer declares QUERY_ALL_PACKAGES or a
        signature|knownSigner BIND_ML_SERVICE permission. The trust boundary
        is per-app user consent via ConsentActivity. Any app may bind to
        MindlayerMlService, but every AIDL method except requestConsentChallenge
        and a coarse ping() requires an approved (packageName, signingCert)
        entry that only the consent flow can create. Caller identity is resolved
        via Binder.getCallingUid() for active callers (automatically visible to
        the service per Android's package-visibility rules for bound services),
        so no broad package-visibility permission is needed.
    -->

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Mindlayer"
        android:allowBackup="false"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        tools:replace="android:dataExtractionRules">

        <uses-native-library android:name="libvndksupport.so" android:required="false" />
        <uses-native-library android:name="libOpenCL.so" android:required="false" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            v0.10 consent-Intent flow (docs/CONSENT_ARCHITECTURE.md).
            Launched only by an explicit, Mindlayer-minted PendingIntent
            (no intent-filter). exported=true is required because the
            PendingIntent is fired by arbitrary client UIDs; the nonce in
            the Intent data is the capability, and lookupChallenge enforces
            self-UID so only Mindlayer can resolve it. excludeFromRecents +
            noHistory keep the consent screen out of the recents list and
            prevent it lingering after the decision.
        -->
        <activity
            android:name=".ui.consent.ConsentActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.Mindlayer" />

        <service
            android:name=".MindlayerMlService"
            android:process=":ml"
            android:exported="true"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="@string/fgs_special_use_description" />
        </service>

    </application>

</manifest>
