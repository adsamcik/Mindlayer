<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.HIDE_OVERLAY_WINDOWS" />
    <!-- F-029: BiometricPrompt for Approve / Revoke gating in the dashboard. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        Android 11 (R, API 30) hides every installed package from
        `PackageManager.getPackageInfo` by default. The Mindlayer service
        cannot enforce its allowlist without seeing the caller's signing
        certificates, so we declare QUERY_ALL_PACKAGES here.

        Why this is the right answer (and not a narrow `<queries>` block):
          - A bound service cannot see its callers without explicit query
            visibility. `<queries><package name="…"/></queries>` would force
            us to enumerate every potential client app at build time, which
            defeats the purpose of a dynamic allowlist + dashboard approval
            flow.
          - `<queries><intent>…</intent></queries>` only matches apps that
            declare a matching `<intent-filter>`. SDK consumers bind to our
            service via AIDL — they have no reason to expose a public
            intent-filter, and forcing them to would leak a discoverable
            attack surface.
          - Google Play policy explicitly permits QUERY_ALL_PACKAGES for
            "apps that need to query and/or interact with any and all
            installed apps for the core user functionality of the app"
            including security / device management tooling. Per-caller
            signing-cert verification is exactly that.
          - Without this permission, the dashboard's Approve button calls
            `CallerVerifier.identifyByPackage` → `pm.getPackageInfo` →
            `NameNotFoundException` (silently filtered) → AllowlistStore
            throws `SecurityException("Package … no longer installed")`,
            even though the package IS installed and the binder DID see it
            when the client first bound. This was the bug that left a
            pending entry stuck because Approve always failed.

        The `tools:ignore="QueryAllPackagesPermission"` below silences
        Android Lint's blanket warning for this permission. The rationale
        above documents the explicit, security-driven need; without the
        ignore, `:app:lintDebug` fails CI because the check's default
        severity is Error and we have `abortOnError = true`.
    -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <permission
        android:name="com.adsamcik.mindlayer.permission.BIND_ML_SERVICE"
        android:label="@string/permission_bind_ml_service_label"
        android:description="@string/permission_bind_ml_service_description"
        android:protectionLevel="signature|knownSigner"
        android:knownCerts="@array/mindlayer_trusted_client_certs" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Mindlayer"
        android:allowBackup="false"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        tools:replace="android:dataExtractionRules">

        <uses-native-library android:name="libvndksupport.so" android:required="false" />
        <uses-native-library android:name="libOpenCL.so" android:required="false" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".MindlayerMlService"
            android:process=":ml"
            android:exported="true"
            android:permission="com.adsamcik.mindlayer.permission.BIND_ML_SERVICE"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="@string/fgs_special_use_description" />
        </service>

    </application>

</manifest>
