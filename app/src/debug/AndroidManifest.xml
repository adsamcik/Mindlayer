<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <permission
        android:name="com.adsamcik.mindlayer.test.permission.KNOWN_CERTS_FORMAT_TEST_LOWERCASE_HEX_64"
        android:knownCerts="@array/knowncerts_format_test_lowercase_hex_64"
        android:protectionLevel="signature|knownSigner" />
    <permission
        android:name="com.adsamcik.mindlayer.test.permission.KNOWN_CERTS_FORMAT_TEST_UPPERCASE"
        android:knownCerts="@array/knowncerts_format_test_uppercase"
        android:protectionLevel="signature|knownSigner" />
    <permission
        android:name="com.adsamcik.mindlayer.test.permission.KNOWN_CERTS_FORMAT_TEST_COLON_PAIRS"
        android:knownCerts="@array/knowncerts_format_test_colon_pairs"
        android:protectionLevel="signature|knownSigner" />
    <permission
        android:name="com.adsamcik.mindlayer.test.permission.KNOWN_CERTS_FORMAT_TEST_LEADING_ZEROX"
        android:knownCerts="@array/knowncerts_format_test_leading_zerox"
        android:protectionLevel="signature|knownSigner" />
    <permission
        android:name="com.adsamcik.mindlayer.test.permission.KNOWN_CERTS_FORMAT_TEST_MISMATCHED"
        android:knownCerts="@array/knowncerts_format_test_mismatched"
        android:protectionLevel="signature|knownSigner" />
    <permission
        android:name="com.adsamcik.mindlayer.test.permission.KNOWN_CERTS_FORMAT_TEST_EMPTY"
        android:knownCerts="@array/knowncerts_format_test_empty"
        android:protectionLevel="signature|knownSigner" />

    <!--
        DEBUG-ONLY: adb/CI hook for the "auto-accept all callers" developer
        toggle. Absent from release builds (this manifest is debug-only).
        Guarded by android.permission.DUMP so only the shell (adb) and system
        can trigger it; an ordinary app on the device cannot. See
        DebugAutoAcceptReceiver for the adb command.
    -->
    <application>
        <receiver
            android:name="com.adsamcik.mindlayer.service.security.DebugAutoAcceptReceiver"
            android:exported="true"
            android:permission="android.permission.DUMP">
            <intent-filter>
                <action android:name="com.adsamcik.mindlayer.debug.SET_AUTO_ACCEPT" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
