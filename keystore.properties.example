# Copy this file to keystore.properties (at the repo root) and fill in values
# for your release signing key. keystore.properties is gitignored.
#
# Generate a new key with:
#   keytool -genkey -v -keystore mindlayer-release.jks \
#           -alias mindlayer -keyalg RSA -keysize 4096 -validity 36500
#
# Then reference the .jks in `storeFile` below (absolute path, or relative to
# the repo root). See RELEASE.md for the full signing flow.

storeFile=../mindlayer-release.jks
storePassword=CHANGE_ME
keyAlias=mindlayer
keyPassword=CHANGE_ME
