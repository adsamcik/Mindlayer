# Built application files
*.apk
*.aar
*.ap_
*.aab
*.apks

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/
!/app/src/release/

# Gradle files
.gradle/
build/
buildSrc/build/

# Local configuration file (sdk path, etc)
local.properties

# Android Studio / IntelliJ
*.iml
.idea/
.DS_Store
captures/

# Keystore files (do not commit signing keys)
*.jks
*.keystore
keystore.properties

# Google Services
google-services.json

# Large model files — delivered via Play AI Pack, not committed
*.litertlm

# PaddleOCR PP-OCRv5 mobile artifacts — produced at build time by the
# .github/workflows/build-paddleocr-models.yml pipeline (paddle2onnx
# -> onnx2tf) and delivered via Play AI Pack. Never committed. See
# paddleocr_model/src/main/assets/.gitkeep for details.
*.tflite
paddleocr_model/src/main/assets/paddleocr-ppocrv5-mobile-*.txt
# SentencePiece tokenizer binaries (e.g. EmbeddingGemma's .spm.model).
# Delivered via Play AI Pack alongside the matching .tflite; same
# distribution + integrity-pinning story as the .tflite files.
*.spm.model
# Intermediate ONNX conversion artifacts (the workflow's transient
# output). Also produced by paddle2onnx and never shipped on-device.
*.onnx
*.onnx.data

# Bundletool
bundletool*.jar

# Kotlin compiler error logs
.kotlin/

# Research prompts (kept locally, not committed)
prompts/

# OS files
Thumbs.db
.DS_Store
*~

# Kotlin
*.kotlin_module

# Test output
test-results/
reports/

# F-047: ad-hoc logcat dumps may contain device serials, package
# names, prompt text and other PII. Captured locally for debugging,
# never committed. Delete from your working tree once you're done.
logcat*.txt
*.logcat
adb-*.log

.pr5-msg.txt
