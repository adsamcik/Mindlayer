<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Mindlayer first-party OCR driver / validation harness.

        This sample app exists solely to:
          1. Demonstrate the cross-app OCR APIs end-to-end (single-image
             `ocrImage` + multi-frame `ocrSession`) as a reference for
             external SDK consumers.
          2. Drive the v0.9 OCR production-readiness validation matrix
             from `docs/OCR_VALIDATION_REPORT.md` — open the service
             connection, exercise each documented scenario, write a JSON
             report to `externalFilesDir/ocr-validation/`.

        No bind permission is required: Mindlayer dropped the
        `BIND_ML_SERVICE` signature permission. Any installed app can bind
        the service; access is gated per-app by explicit USER CONSENT. The
        Connection tab's "Request consent" button launches the Mindlayer
        consent screen (MindlayerConsent.requestConsent); after the user
        approves once, Connect succeeds. That consent handshake is part of
        what this harness exercises.

        The <queries> block keeps the service package visible to this app on
        Android 11+ (package-visibility), which the SDK needs to resolve and
        bind the service by component name. It is NOT QUERY_ALL_PACKAGES —
        only the two Mindlayer service packages are listed.

        No INTERNET / CAMERA permissions: the realtime scenarios feed
        pre-bundled fixture images into the OCR session as encoded
        frames, exactly like a CameraX adapter would, but without the
        OS camera dependency. That keeps the validation harness
        deterministic and runnable on emulators with no virtual camera.
    -->

    <queries>
        <package android:name="com.adsamcik.mindlayer.service" />
        <package android:name="com.adsamcik.mindlayer.service.debug" />
    </queries>

    <application
        android:label="Mindlayer OCR Driver"
        android:theme="@android:style/Theme.Material.Light.NoActionBar"
        android:allowBackup="false">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
